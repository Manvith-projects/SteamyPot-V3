# MongoDB connections used by AI modules
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MAIN_APP_MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Gemini API key for LLM-powered services
GOOGLE_API_KEY=your_google_gemini_api_key

# Optional tuning
REVIEW_CACHE_TTL_HOURS=24
